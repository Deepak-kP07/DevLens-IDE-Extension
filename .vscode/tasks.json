{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "devlens:build-extension",
      "type": "shell",
      "command": "npm run build:extension",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$tsc"
    },
    {
      "label": "devlens:run-backend",
      "type": "shell",
      "command": "npm run dev:backend",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}
